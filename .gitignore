# .gitignore for lc29h_da_rtk_gps_driver
# Ignore Python bytecode and build artifacts
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
venv/
ENV/
.env
.envrc
.venv/

# Tests and caches
.pytest_cache/
.mypy_cache/

# Coverage reports
.coverage
.coverage.*
htmlcov/

# Editor directories and files
.vscode/
.idea/
*.swp
